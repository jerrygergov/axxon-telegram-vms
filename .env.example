# Enable this so per-user settings (for example /tz) survive bot restarts.
AXXON_SECURE_PROFILE_ENABLED=1
# Generate once and keep private, for example with:
# python3 - <<'PY'
# from cryptography.fernet import Fernet
# print(Fernet.generate_key().decode())
# PY
AXXON_SECURE_PROFILE_MASTER_KEY=
# Example: /home/%username%/axxon-telegram-vms/.secure_profiles
AXXON_SECURE_PROFILE_DIR=

AXXON_RELAY_HOST=0.0.0.0
AXXON_RELAY_PORT=8099
AXXON_RELAY_PUBLIC_BASE=
