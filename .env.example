TG_BOT_TOKEN=
AXXON_HOST=
AXXON_PORT=80
AXXON_USER=root
AXXON_PASS=
AUTHORIZED_USERS=
ADMIN_USERS=
TG_MAX_EVENTS_PER_DAY=1000
